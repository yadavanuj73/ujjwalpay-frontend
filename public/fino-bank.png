9, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD}@font-face{font-family: 'Work Sans'; font-style: italic; font-weight: 600; font-display: swap; src: url(https://fonts.gstatic.com/s/worksans/v24/QGYqz_wNahGAdqQ43Rh_eZDrv_0.woff2) format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD}@font-face{font-family: 'Work Sans'; font-style: italic; font-weight: 700; font-display: swap; src: url(https://fonts.gstatic.com/s/worksans/v24/QGYqz_wNahGAdqQ43Rh_eZDrv_0.woff2) format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD}@font-face{font-family: 'Work Sans'; font-style: normal; font-weight: 400; font-display: swap; src: url(https://fonts.gstatic.com/s/worksans/v24/QGYsz_wNahGAdqQ43Rh_fKDp.woff2) format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD}@font-face{font-family: 'Work Sans'; font-style: normal; font-weight: 500; font-display: swap; src: url(https://fonts.gstatic.com/s/worksans/v24/QGYsz_wNahGAdqQ43Rh_fKDp.woff2) format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD}@font-face{font-family: 'Work Sans'; font-style: normal; font-weight: 600; font-display: swap; src: url(https://fonts.gstatic.com/s/worksans/v24/QGYsz_wNahGAdqQ43Rh_fKDp.woff2) format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD}@font-face{font-family: 'Work Sans'; font-style: normal; font-weight: 700; font-display: swap; src: url(https://fonts.gstatic.com/s/worksans/v24/QGYsz_wNahGAdqQ43Rh_fKDp.woff2) format('woff2'); unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD}:root{--pub-font-family: Work Sans, Helvetica, Arial, sans-serif; --pub-font-family-secondary: Poppins, Helvetica, Arial, sans-serif}","postsByCategory":[],"slots":{"web_story":{"id":52307,"name":"Web Story","data":{"size":"autoxauto","contains_ads":0,"html_content":"\u0026lt;h1\u0026gt;\n    hello\n    \u0026lt;/h1\u0026gt;","override_slot_data":[],"slots_override_enabled":false},"registered_slot":{"id":670,"name":"web_story","data":null,"page":"others","updated_at":"2025-10-10T00:51:26.993060+05:30"},"formatted_update_on":"22 Jan 2026","type":"CodeEditor"},"web_story_head":{"id":52308,"name":"web story ehad","data":{"size":"autoxauto","contains_ads":0,"html_content":"\u0026lt;script\u0026gt;\n    hello\n    \u0026lt;/script\u0026gt;","override_slot_data":[],"slots_override_enabled":false},"registered_slot":{"id":700,"name":"web_story_head","data":null,"page":"others","updated_at":"2026-02-18T16:51:48.990632+05:30"},"formatted_update_on":"22 Jan 2026","type":"CodeEditor"},"desktop_universal_css":{"id":52274,"name":"date reomval on investorRelation page","data":{"size":"autoxauto","contains_ads":0,"html_content":"\u0026lt;style\u0026gt;\nbody:has(main[class*=\u0026quot;investorRelation_investorRelationPage\u0026quot;])\np.font-normal.text-left.text-\\[\\#807D94\\].text-sm.sm\\:text-base.whitespace-nowrap {\n  /* display: none !important; */\n}\n\u0026lt;/style\u0026gt;\n\u0026lt;style\u0026gt;\n.pl-floating-actions{\n  position: fixed;\n  right: 18px;\n  top: 50%;\n  transform: translateY(-50%);\n  display: flex;\n  flex-direction: column;\n  gap: 14px;\n  z-index: 10;\n}\n\n\n.pl-fab{\n  width: 56px;\n  height: 56px;\n  background: #ffffff;\n  border-radius: 50%;\n  box-shadow: 0 10px 22px rgba(0,0,0,.12);\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  text-decoration: none;\n  overflow: hidden;\n  transition: height .35s ease, background .35s ease;\n}\n\n\n.pl-fab-icon{\n  width: 28px;\n  height: 28px;\n  position: absolute;\n  transition: transform .4s ease;\n}\n\n\n.pl-fab-label{\n  writing-mode: vertical-rl;\n  transform: rotate(180deg);\n  font-size: 16px;\n  font-weight: 500;\n  color: #1f2a44;\n  margin-top: 20px;\n  opacity: 0;\n  transition: opacity .25s ease;\n}\n\n.pl-fab:hover{\n  height: 180px;              \n  background: #d4d4ff;          \n  border-radius: 28px;\n}\n\n\n.pl-fab:hover .pl-fab-label{\n  opacity: 1;\n}\n\n\n.pl-fab:hover .pl-fab-icon{\n  transform: translateY(-60px);\n}\n\u0026lt;/style\u0026gt;\n\u0026lt;style\u0026gt;\n.skiptranslate.goog-te-gadget {\n    padding: 7px 16px;\n    position: relative;\n    color: white;\n}\n.skiptranslate.goog-te-gadget span {\n    display: none;\n}\n.skiptranslate.goog-te-gadget {\n    font-size:0px;\n}\n\u0026lt;/style\u0026gt;","override_slot_data":[],"slots_override_enabled":true},"registered_slot":{"id":1564,"name":"desktop_universal_css","data":{"size":[]},"page":"others","updated_at":"2026-04-10T17:02:28.419630+05:30"},"formatted_update_on":"25 Feb 2026","type":"CodeEditor"},"web_story_css":{"id":52306,"name":"CSS","data":{"size":"autoxauto","contains_ads":0,"html_content":".body{}","override_slot_data":[],"slots_override_enabled":false},"registered_slot":{"id":701,"name":"web_story_css","data":null,"page":"others","updated_at":"2025-10-10T00:51:27.012907+05:30"},"formatted_update_on":"22 Jan 2026","type":"CodeEditor"},"desktop_universal_body_end":{"id":52492,"name":"wa widget 2","data":{"size":"autoxauto","contains_ads":0,"html_content":"\u0026lt;nav class=\u0026quot;pl-floating-actions\u0026quot; aria-label=\u0026quot;Quick actions\u0026quot;\u0026gt;\n  \u0026lt;a href=\u0026quot;https://wa.me/8657008036\u0026quot; class=\u0026quot;pl-fab\u0026quot;\u0026gt;\n    \u0026lt;img\n      src=\u0026quot;https://static-cdn.publive.online/fino/media/media_files/2026/01/23/cb-wa-2026-01-23-13-56-56.svg\u0026quot;\n      alt=\u0026quot;\u0026quot;\n      aria-hidden=\u0026quot;true\u0026quot;\n      class=\u0026quot;pl-fab-icon\u0026quot;\n    \u0026gt;\n    \u0026lt;span class=\u0026quot;pl-fab-label\u0026quot;\u0026gt;WhatsApp\u0026lt;/span\u0026gt;\n  \u0026lt;/a\u0026gt;\n\n  \u0026lt;a href=\u0026quot;/support/contact-us\u0026quot; class=\u0026quot;pl-fab\u0026quot;\u0026gt;\n    \u0026lt;img\n      src=\u0026quot;https://static-cdn.publive.online/fino/media/media_files/2026/01/23/cb-locate-2026-01-23-13-56-56.svg\u0026quot;\n      alt=\u0026quot;\u0026quot;\n      aria-hidden=\u0026quot;true\u0026quot;\n      class=\u0026quot;pl-fab-icon\u0026quot;\n    \u0026gt;\n    \u0026lt;span class=\u0026quot;pl-fab-label\u0026quot;\u0026gt;Locate Us\u0026lt;/span\u0026gt;\n  \u0026lt;/a\u0026gt;\n\n  \u0026lt;a href=\u0026quot;/support/contact-us\u0026quot; class=\u0026quot;pl-fab\u0026quot;\u0026gt;\n    \u0026lt;img\n      src=\u0026quot;https://static-cdn.publive.online/fino/media/media_files/2026/01/23/raise-complaint-2026-01-23-13-56-56.svg\u0026quot;\n      alt=\u0026quot;\u0026quot;\n      aria-hidden=\u0026quot;true\u0026quot;\n      class=\u0026quot;pl-fab-icon\u0026quot;\n    \u0026gt;\n    \u0026lt;span class=\u0026quot;pl-fab-label\u0026quot;\u0026gt;Raise Complaint\u0026lt;/span\u0026gt;\n  \u0026lt;/a\u0026gt;\n\u0026lt;/nav\u0026gt;\n\u0026lt;script\u0026gt;\n(async function () {\n  try {\n    // Run only when path is /support/contact-us\n    if (window.location.pathname !== \u0026quot;/support/contact-us\u0026quot;) return;\n\n    await new Promise((resolve) =\u0026gt; {\n      if (document.readyState === \u0026quot;complete\u0026quot;) return resolve();\n      window.addEventListener(\u0026quot;load\u0026quot;, resolve);\n    });\n\n    let tries = 0;\n    const maxTries = 20;\n\n    const interval = setInterval(() =\u0026gt; {\n      tries++;\n\n      const panel = document.querySelector(\u0026quot;#locate-us-panel\u0026quot;);\n      if (!panel) {\n        if (tries \u0026gt;= maxTries) clearInterval(interval);\n        return;\n      }\n\n      clearInterval(interval);\n      if (panel.querySelector(\u0026quot;.custom-locate-launcher\u0026quot;)) return;\n\n      // Launcher button\n      const launcher = document.createElement(\u0026quot;button\u0026quot;);\n      launcher.className = \u0026quot;custom-locate-launcher\u0026quot;;\n      launcher.type = \u0026quot;button\u0026quot;;\n      launcher.innerText = \u0026quot;Open Branch Locator\u0026quot;;\n      launcher.style.cssText = `\n        width:100%;\n        margin: 0 0 16px 0;\n        padding: 14px 16px;\n        border-radius: 12px;\n        border: 1px solid #d9d9d9;\n        font-weight: 600;\n        cursor: pointer;\n        background: #fff;\n      `;\n\n      // Modal\n      const modal = document.createElement(\u0026quot;div\u0026quot;);\n      modal.className = \u0026quot;custom-locate-modal\u0026quot;;\n      modal.style.cssText = `\n        display:none;\n        position:fixed;\n        inset:0;\n        background: rgba(0,0,0,0.55);\n        z-index: 999999;\n        padding: 12px;\n      `;\n\n      modal.innerHTML = `\n        \u0026lt;div class=\u0026quot;custom-locate-modal-inner\u0026quot; style=\u0026quot;\n          width: 100%;\n          height: 100%;\n          background: #fff;\n          border-radius: 14px;\n          overflow: hidden;\n          position: relative;\n        \u0026quot;\u0026gt;\n\n          \u0026lt;!-- ✅ Fixed top bar so close works on mobile --\u0026gt;\n          \u0026lt;div class=\u0026quot;custom-locate-topbar\u0026quot; style=\u0026quot;\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            height: 56px;\n            padding-top: env(safe-area-inset-top);\n            background: rgba(255,255,255,0.98);\n            display: flex;\n            align-items: center;\n            justify-content: flex-end;\n            z-index: 10;\n            box-shadow: 0 1px 0 rgba(0,0,0,0.08);\n          \u0026quot;\u0026gt;\n\n            \u0026lt;!-- ✅ Logo click overlay (top-left) --\u0026gt;\n            \u0026lt;a\n              href=\u0026quot;https://fino.latlong.in\u0026quot;\n              target=\u0026quot;_blank\u0026quot;\n              rel=\u0026quot;noopener noreferrer\u0026quot;\n              aria-label=\u0026quot;Open Branch Locator in new tab\u0026quot;\n              style=\u0026quot;\n                position:absolute;\n                top: 0;\n                left: 0;\n                width: 300px;   /* adjust if needed */\n                height: 150px;\n                z-index: 11;\n                background: transparent;\n              \u0026quot;\u0026gt;\n            \u0026lt;/a\u0026gt;\n\n            \u0026lt;!-- ✅ Mobile-friendly close button --\u0026gt;\n            \u0026lt;button type=\u0026quot;button\u0026quot; class=\u0026quot;custom-locate-close\u0026quot; aria-label=\u0026quot;Close\u0026quot; style=\u0026quot;\n              width: 44px;\n              height: 44px;\n              margin-right: 10px;\n              border: 0;\n              background: #fff;\n              border-radius: 12px;\n              cursor: pointer;\n              font-size: 20px;\n              line-height: 44px;\n              text-align: center;\n              box-shadow: 0 1px 4px rgba(0,0,0,0.12);\n            \u0026quot;\u0026gt;✕\u0026lt;/button\u0026gt;\n          \u0026lt;/div\u0026gt;\n\n          \u0026lt;!-- Iframe pushed below topbar --\u0026gt;\n          \u0026lt;iframe\n            src=\u0026quot;https://fino.latlong.in/\u0026quot;\n            style=\u0026quot;\n              width:100%;\n              height:100%;\n              border:0;\n              display:block;\n              padding-top: 56px; /* ensures iframe content not under topbar */\n              box-sizing: border-box;\n            \u0026quot;\n            loading=\u0026quot;lazy\u0026quot;\n            allowfullscreen\u0026gt;\n          \u0026lt;/iframe\u0026gt;\n        \u0026lt;/div\u0026gt;\n      `;\n\n      function openModal() {\n        modal.style.display = \u0026quot;block\u0026quot;;\n        document.documentElement.style.overflow = \u0026quot;hidden\u0026quot;;\n      }\n\n      function closeModal() {\n        modal.style.display = \u0026quot;none\u0026quot;;\n        document.documentElement.style.overflow = \u0026quot;\u0026quot;;\n      }\n\n      launcher.addEventListener(\u0026quot;click\u0026quot;, openModal);\n\n      // click outside closes\n      modal.addEventListener(\u0026quot;click\u0026quot;, (e) =\u0026gt; {\n        if (e.target === modal) closeModal();\n      });\n\n      modal.querySelector(\u0026quot;.custom-locate-close\u0026quot;).addEventListener(\u0026quot;click\u0026quot;, closeModal);\n\n      // ESC key closes\n      window.addEventListener(\u0026quot;keydown\u0026quot;, (e) =\u0026gt; {\n        if (e.key === \u0026quot;Escape\u0026quot; \u0026amp;\u0026amp; modal.style.display === \u0026quot;block\u0026quot;) closeModal();\n      });\n\n      panel.insertBefore(launcher, panel.firstElementChild);\n      document.body.appendChild(modal);\n\n    }, 400);\n\n  } catch (err) {\n    console.error(\u0026quot;Locate modal injection failed:\u0026quot;, err);\n  }\n})();\n\u0026lt;/script\u0026gt;\n\u0026lt;script\u0026gt;\n(async function () {\n  try {\n    const allowedUrl = \u0026quot;https://www.fino.bank.in/support/contact-us\u0026quot;;\n    if (window.location.href.split(\u0026quot;?\u0026quot;)[0] !== allowedUrl) return;\n\n    await new Promise((resolve) =\u0026gt; {\n      if (document.readyState === \u0026quot;complete\u0026quot;) return resolve();\n      window.addEventListener(\u0026quot;load\u0026quot;, resolve);\n    });\n\n    let tries = 0;\n    const maxTries = 20;\n\n    const interval = setInterval(() =\u0026gt; {\n      tries++;\n\n      const panel = document.querySelector(\u0026quot;#locate-us-panel\u0026quot;);\n      if (panel) {\n        clearInterval(interval);\n\n        if (panel.querySelector(\u0026quot;.custom-locate-iframe\u0026quot;)) return;\n\n        const wrap = document.createElement(\u0026quot;div\u0026quot;);\n        wrap.className = \u0026quot;custom-locate-iframe\u0026quot;;\n        wrap.style.marginBottom = \u0026quot;20px\u0026quot;;\n        wrap.style.borderRadius = \u0026quot;12px\u0026quot;;\n        wrap.style.overflow = \u0026quot;hidden\u0026quot;;\n        wrap.style.position = \u0026quot;relative\u0026quot;; // ✅ needed for overlay positioning\n\n        const iframe = document.createElement(\u0026quot;iframe\u0026quot;);\n        iframe.src = \u0026quot;https://fino.latlong.in/\u0026quot;;\n        iframe.width = \u0026quot;100%\u0026quot;;\n        iframe.height = \u0026quot;600\u0026quot;;\n        iframe.style.border = \u0026quot;0\u0026quot;;\n        iframe.style.display = \u0026quot;block\u0026quot;;\n        iframe.style.overflow = \u0026quot;hidden\u0026quot;;\n        iframe.setAttribute(\u0026quot;scrolling\u0026quot;, \u0026quot;no\u0026quot;);\n\n        // ✅ Logo overlay link (top-left)\n        const logoLink = document.createElement(\u0026quot;a\u0026quot;);\n        logoLink.href = \u0026quot;https://fino.latlong.in\u0026quot;;\n        logoLink.target = \u0026quot;_blank\u0026quot;;\n        logoLink.rel = \u0026quot;noopener noreferrer\u0026quot;;\n        logoLink.setAttribute(\u0026quot;aria-label\u0026quot;, \u0026quot;Open Branch Locator in new tab\u0026quot;);\n        logoLink.style.cssText = `\n          position: absolute;\n          top: 0;\n          left: 0;\n          width: 300px;   /* adjust based on logo width */\n          height: 100px;   /* adjust based on header height */\n          z-index: 5;\n          background: transparent;\n        `;\n\n        wrap.appendChild(iframe);\n        wrap.appendChild(logoLink);\n\n        panel.insertBefore(wrap, panel.firstElementChild);\n      }\n\n      if (tries \u0026gt;= maxTries) clearInterval(interval);\n    }, 400);\n\n  } catch (err) {\n    console.error(\u0026quot;Locate iframe injection failed:\u0026quot;, err);\n  }\n})();\n\u0026lt;/script\u0026gt;\n\u0026lt;script\u0026gt;\n(function () {\n  try {\n    if (location.pathname !== \u0026quot;/support/contact-us\u0026quot;) return;\n\n    // Inject strong CSS override\n    const style = document.createElement(\u0026quot;style\u0026quot;);\n    style.innerHTML = `\n      label input[type=\u0026quot;checkbox\u0026quot;]:not(:checked) + div {\n        background-color: red !important;\n      }\n      label input[type=\u0026quot;checkbox\u0026quot;]:checked + div {\n        background-color: green !important;\n      }\n    `;\n    document.head.appendChild(style);\n\n  } catch (e) {\n    console.error(e);\n  }\n})();\n\u0026lt;/script\u0026gt;","override_slot_data":[],"slots_override_enabled":true},"registered_slot":{"id":1569,"name":"desktop_universal_body_end","data":{"size":[]},"page":"others","updated_at":"2026-04-30T12:04:12.751482+05:30"},"formatted_update_on":"02 Feb 2026","type":"CodeEditor"}}},"__N_SSP":true},"page":"/[...slug]","query":{"slug":["home"]},"buildId":"3wGOFwqRt0EHjLrcgc1MV","isFallback":false,"isExperimentalCompile":false,"dynamicIds":[7642,6380,6234,2759,1941,131,5137,2202,9847],"gssp":true,"scriptLoader":[]}</script></body></html>