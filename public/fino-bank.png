<script>
(async function () {
  try {
    // Run only when path is /support/contact-us
    if (window.location.pathname !== "/support/contact-us") return;

    await new Promise((resolve) => {
      if (document.readyState === "complete") return resolve();
      window.addEventListener("load", resolve);
    });

    let tries = 0;
    const maxTries = 20;

    const interval = setInterval(() => {
      tries++;

      const panel = document.querySelector("#locate-us-panel");
      if (!panel) {
        if (tries >= maxTries) clearInterval(interval);
        return;
      }

      clearInterval(interval);
      if (panel.querySelector(".custom-locate-launcher")) return;

      // Launcher button
      const launcher = document.createElement("button");
      launcher.className = "custom-locate-launcher";
      launcher.type = "button";
      launcher.innerText = "Open Branch Locator";
      launcher.style.cssText = `
        width:100%;
        margin: 0 0 16px 0;
        padding: 14px 16px;
        border-radius: 12px;
        border: 1px solid #d9d9d9;
        font-weight: 600;
        cursor: pointer;
        background: #fff;
      `;

      // Modal
      const modal = document.createElement("div");
      modal.className = "custom-locate-modal";
      modal.style.cssText = `
        display:none;
        position:fixed;
        inset:0;
        background: rgba(0,0,0,0.55);
        z-index: 999999;
        padding: 12px;
      `;

      modal.innerHTML = `
        <div class="custom-locate-modal-inner" style="
          width: 100%;
          height: 100%;
          background: #fff;
          border-radius: 14px;
          overflow: hidden;
          position: relative;
        ">

          <!-- ✅ Fixed top bar so close works on mobile -->
          <div class="custom-locate-topbar" style="
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 56px;
            padding-top: env(safe-area-inset-top);
            background: rgba(255,255,255,0.98);
            display: flex;
            align-items: center;
            justify-content: flex-end;
            z-index: 10;
            box-shadow: 0 1px 0 rgba(0,0,0,0.08);
          ">

            <!-- ✅ Logo click overlay (top-left) -->
            <a
              href="https://fino.latlong.in"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Open Branch Locator in new tab"
              style="
                position:absolute;
                top: 0;
                left: 0;
                width: 300px;   /* adjust if needed */
                height: 150px;
                z-index: 11;
                background: transparent;
              ">
            </a>

            <!-- ✅ Mobile-friendly close button -->
            <button type="button" class="custom-locate-close" aria-label="Close" style="
              width: 44px;
              height: 44px;
              margin-right: 10px;
              border: 0;
              background: #fff;
              border-radius: 12px;
              cursor: pointer;
              font-size: 20px;
              line-height: 44px;
              text-align: center;
              box-shadow: 0 1px 4px rgba(0,0,0,0.12);
            ">✕</button>
          </div>

          <!-- Iframe pushed below topbar -->
          <iframe
            src="https://fino.latlong.in/"
            style="
              width:100%;
              height:100%;
              border:0;
              display:block;
              padding-top: 56px; /* ensures iframe content not under topbar */
              box-sizing: border-box;
            "
            loading="lazy"
            allowfullscreen>
          </iframe>
        </div>
      `;

      function openModal() {
        modal.style.display = "block";
        document.documentElement.style.overflow = "hidden";
      }

      function closeModal() {
        modal.style.display = "none";
        document.documentElement.style.overflow = "";
      }

      launcher.addEventListener("click", openModal);

      // click outside closes
      modal.addEventListener("click", (e) => {
        if (e.target === modal) closeModal();
      });

      modal.querySelector(".custom-locate-close").addEventListener("click", closeModal);

      // ESC key closes
      window.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && modal.style.display === "block") closeModal();
      });

      panel.insertBefore(launcher, panel.firstElementChild);
      document.body.appendChild(modal);

    }, 400);

  } catch (err) {
    console.error("Locate modal injection failed:", err);
  }
})();
</script>
<script>
(async function () {
  try {
    const allowedUrl = "https://www.fino.bank.in/support/contact-us";
    if (window.location.href.split("?")[0] !== allowedUrl) return;

    await new Promise((resolve) => {
      if (document.readyState === "complete") return resolve();
      window.addEventListener("load", resolve);
    });

    let tries = 0;
    const maxTries = 20;

    const interval = setInterval(() => {
      tries++;

      const panel = document.querySelector("#locate-us-panel");
      if (panel) {
        clearInterval(interval);

        if (panel.querySelector(".custom-locate-iframe")) return;

        const wrap = document.createElement("div");
        wrap.className = "custom-locate-iframe";
        wrap.style.marginBottom = "20px";
        wrap.style.borderRadius = "12px";
        wrap.style.overflow = "hidden";
        wrap.style.position = "relative"; // ✅ needed for overlay positioning

        const iframe = document.createElement("iframe");
        iframe.src = "https://fino.latlong.in/";
        iframe.width = "100%";
        iframe.height = "600";
        iframe.style.border = "0";
        iframe.style.display = "block";
        iframe.style.overflow = "hidden";
        iframe.setAttribute("scrolling", "no");

        // ✅ Logo overlay link (top-left)
        const logoLink = document.createElement("a");
        logoLink.href = "https://fino.latlong.in";
        logoLink.target = "_blank";
        logoLink.rel = "noopener noreferrer";
        logoLink.setAttribute("aria-label", "Open Branch Locator in new tab");
        logoLink.style.cssText = `
          position: absolute;
          top: 0;
          left: 0;
          width: 300px;   /* adjust based on logo width */
          height: 100px;   /* adjust based on header height */
          z-index: 5;
          background: transparent;
        `;

        wrap.appendChild(iframe);
        wrap.appendChild(logoLink);

        panel.insertBefore(wrap, panel.firstElementChild);
      }

      if (tries >= maxTries) clearInterval(interval);
    }, 400);

  } catch (err) {
    console.error("Locate iframe injection failed:", err);
  }
})();
</script>
<script>
(function () {
  try {
    if (location.pathname !== "/support/contact-us") return;

    // Inject strong CSS override
    const style = document.createElement("style");
    style.innerHTML = `
      label input[type="checkbox"]:not(:checked) + div {
        background-color: red !important;
      }
      label input[type="checkbox"]:checked + div {
        background-color: green !important;
      }
    `;
    document.head.appendChild(style);

  } catch (e) {
    console.error(e);
  }
})();
