.pl-floating-actions{
  position: fixed;
  right: 18px;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  gap: 14px;
  z-index: 10;
}


.pl-fab{
  width: 56px;
  height: 56px;
  background: #ffffff;
  border-radius: 50%;
  box-shadow: 0 10px 22px rgba(0,0,0,.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  overflow: hidden;
  transition: height .35s ease, background .35s ease;
}


.pl-fab-icon{
  width: 28px;
  height: 28px;
  position: absolute;
  transition: transform .4s ease;
}


.pl-fab-label{
  writing-mode: vertical-rl;
  transform: rotate(180deg);
  font-size: 16px;
  font-weight: 500;
  color: #1f2a44;
  margin-top: 20px;
  opacity: 0;
  transition: opacity .25s ease;
}

.pl-fab:hover{
  height: 180px;              
  background: #d4d4ff;          
  border-radius: 28px;
}


.pl-fab:hover .pl-fab-label{
  opacity: 1;
}


.pl-fab:hover .pl-fab-icon{
  transform: translateY(-60px);
}
</style><style data-next-head="">
